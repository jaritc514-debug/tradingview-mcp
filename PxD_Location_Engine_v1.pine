//@version=5
// ═══════════════════════════════════════════════════════════════════
// PxD LOCATION ENGINE v1 — BUILD STAGE: Night 3 rev C (cumulative)
// Night 2 ✔ Layer 1 ZigZag (gate passed 50/50 EURUSD D+4H)
// Night 3 ▶ Structure labels (STRICT) + Regime state machine + dashboard
//   rev B: confirmation logic moved from function to global scope
//   rev C: TF label converter (240→4H etc, mirror-format compliance);
//          dashboard position input (default Bottom Right, clears TV
//          logo + leaves bottom-left free for the paid tool's table)
//   rev D: verification table now created ONLY when toggled on — its
//          empty ghost was squatting bottom_right and hiding the dash
// Night 4 ▷ Location + verdict matrix + MTF dashboard (1D+4H rows)
//
// SPEC.md v1.1 rules enforced here:
//  - Confirmed pivots only. Developing extreme feeds NOTHING.
//  - Labels: STRICT comparisons. Exactly-equal pivot = NEITHER stream.
//  - Regime flip: candle CLOSE beyond most recent opposing confirmed
//    pivot. Wicks never flip. Buffer input exists, DEFAULT 0 (dormant).
//  - Status: 1 qualifying pivot = Unconfirmed, 2+ = Confirmed.
//    Launch pivot counts as #1 only if it truly qualified (HL/LH).
//  - Wick-only counter-pivot: regime survives, count resets to 0.
// ═══════════════════════════════════════════════════════════════════
indicator("PxD Location Engine v1", overlay=true, max_lines_count=500, max_labels_count=500, max_bars_back=5000)

// ── Inputs — Layer 1 Pivot Engine ───────────────────────────────────
grp      = "Pivot Engine (Layer 1 — ZigZag)"
depth    = input.int(12, "Depth (min bars to form a new pivot)", minval=2,  group=grp)
devTicks = input.int(3,  "Deviation (min ticks to form a new pivot)", minval=0, group=grp)
backstep = input.int(1,  "Backstep (bars to confirm)", minval=1, group=grp)
showDev  = input.bool(true, "Show developing (unconfirmed) leg", group=grp)
showDots = input.bool(false, "Show pivot markers", group=grp)
zzColor  = input.color(color.new(#f0c040, 0), "Confirmed ZigZag Color", group=grp)
devColor = input.color(color.new(color.gray, 40), "Developing Leg Color", group=grp)
lineW    = input.int(2, "Line Width", minval=1, maxval=4, group=grp)

grpS     = "Structure & Regime (Night 3)"
showLbls = input.bool(true, "Show HH/HL/LH/LL labels", group=grpS)
lblColor = input.color(color.new(color.white, 20), "Label Color", group=grpS)
bufAtrM  = input.float(0.0, "Break buffer (ATR mult) — DORMANT, keep 0 during validation", minval=0.0, maxval=1.0, step=0.05, group=grpS)
atrLenB  = input.int(14, "Buffer ATR length", group=grpS)
showDash = input.bool(true, "Show Status/Trend dashboard", group=grpS)
dashPos  = input.string("Bottom Right", "Dashboard Position", options=["Top Left","Top Right","Bottom Left","Bottom Right","Middle Right"], group=grpS)

grpDbg   = "Verification Aids"
showTbl  = input.bool(false, "Show pivot verification table", group=grpDbg)
tblRows  = input.int(10, "Pivots listed in table", minval=5, maxval=20, group=grpDbg)

dev    = devTicks * syminfo.mintick
bufAbs = bufAtrM * ta.atr(atrLenB)

// ── Window extremum qualification ───────────────────────────────────
isWinHigh = ta.highestbars(high, depth) == 0
isWinLow  = ta.lowestbars(low,  depth) == 0

// ── ZigZag state (Layer 1 — unchanged, gate-passed) ─────────────────
var int   dir     = 0
var float candPx  = na
var int   candBar = na

var array<float> zzPx  = array.new_float()
var array<int>   zzBar = array.new_int()
var array<int>   zzDir = array.new_int()   // +1 = high, -1 = low
var array<line>  zzLn  = array.new<line>()
var array<label> zzLb  = array.new<label>()

MAXPIV = 120

// ── Structure & regime state ─────────────────────────────────────────
var float lastHi    = na   // previous confirmed HIGH pivot price
var float lastLo    = na   // previous confirmed LOW pivot price
var int   lastHiCls = 0    // newest high:  1=HH, -1=LH, 0=equal/none
var int   lastLoCls = 0    // newest low:   1=HL, -1=LL, 0=equal/none

var int regime   = 0       // +1 bullish, -1 bearish, 0 = cold start
var int regCount = 0       // consecutive qualifying pivots in regime

var float refHi = na       // newest confirmed high = bullish break ref
var float refLo = na       // newest confirmed low  = bearish break ref

// ── Per-bar ZigZag state machine ─────────────────────────────────────
// Sets a confirmation flag; the actual confirmation work happens below
// at global scope (Pine cannot mutate globals inside functions).
bool  doConf  = false
float confPx  = na
int   confBar = na
int   confDir = 0

if dir == 0
    if isWinHigh
        dir := 1
        candPx := high
        candBar := bar_index
    else if isWinLow
        dir := -1
        candPx := low
        candBar := bar_index
else if dir == 1
    if isWinHigh and high >= candPx
        candPx := high
        candBar := bar_index
    if isWinLow and (candPx - low >= dev) and (bar_index - candBar >= backstep)
        doConf  := true
        confPx  := candPx
        confBar := candBar
        confDir := 1
        dir     := -1
        candPx  := low
        candBar := bar_index
else if dir == -1
    if isWinLow and low <= candPx
        candPx := low
        candBar := bar_index
    if isWinHigh and (high - candPx >= dev) and (bar_index - candBar >= backstep)
        doConf  := true
        confPx  := candPx
        confBar := candBar
        confDir := -1
        dir     := 1
        candPx  := high
        candBar := bar_index

// ── Pivot confirmation (global scope) ───────────────────────────────
if doConf
    // zigzag segment from previous confirmed pivot
    if array.size(zzPx) > 0
        pPx = array.get(zzPx, array.size(zzPx) - 1)
        pBx = array.get(zzBar, array.size(zzBar) - 1)
        array.push(zzLn, line.new(pBx, pPx, confBar, confPx, color=zzColor, width=lineW))
    // ── structure classification (STRICT) ──
    string sTxt = ""
    if confDir == 1
        int cls = na(lastHi) ? 0 : confPx > lastHi ? 1 : confPx < lastHi ? -1 : 0
        lastHiCls := cls
        sTxt := cls == 1 ? "HH" : cls == -1 ? "LH" : ""
        // in a BEARISH regime, highs are the qualifying stream
        if regime == -1
            if cls == -1
                regCount := regCount + 1
            else if cls == 1
                regCount := 0   // wick-made HH, no close-break: reset, regime survives
        lastHi := confPx
        refHi  := confPx
    else
        int cls = na(lastLo) ? 0 : confPx > lastLo ? 1 : confPx < lastLo ? -1 : 0
        lastLoCls := cls
        sTxt := cls == 1 ? "HL" : cls == -1 ? "LL" : ""
        if regime == 1
            if cls == 1
                regCount := regCount + 1
            else if cls == -1
                regCount := 0   // wick-made LL in bullish regime: reset, survive
        lastLo := confPx
        refLo  := confPx
    // markers & labels
    if showDots
        array.push(zzLb, label.new(confBar, confPx, "●", color=color.new(color.white, 100), textcolor=zzColor,
             style=confDir == 1 ? label.style_label_down : label.style_label_up, size=size.tiny))
    if showLbls and sTxt != ""
        array.push(zzLb, label.new(confBar, confPx, sTxt, color=color.new(color.white, 100), textcolor=lblColor,
             style=confDir == 1 ? label.style_label_down : label.style_label_up, size=size.small))
    array.push(zzPx, confPx)
    array.push(zzBar, confBar)
    array.push(zzDir, confDir)
    if array.size(zzPx) > MAXPIV
        array.shift(zzPx)
        array.shift(zzBar)
        array.shift(zzDir)
        if array.size(zzLn) > 0
            line.delete(array.shift(zzLn))
        if array.size(zzLb) > 0
            label.delete(array.shift(zzLb))

// ── Regime flips — CLOSED bars only, close-beyond only ──────────────
if barstate.isconfirmed or barstate.ishistory
    if not na(refHi) and regime <= 0 and close > refHi + bufAbs
        regime   := 1
        regCount := lastLoCls == 1 ? 1 : 0   // launch HL counts only if it qualified
    else if not na(refLo) and regime >= 0 and close < refLo - bufAbs
        regime   := -1
        regCount := lastHiCls == -1 ? 1 : 0

// ── Status / Trend outputs ───────────────────────────────────────────
statusTxt = regime == 0 ? "—" : regCount >= 2 ? "Confirmed" : "Unconfirmed"
trendTxt  = regime == 1 ? "Bullish" : regime == -1 ? "Bearish" : "Sideways"
statusCol = regime == 0 ? color.white : regCount >= 2 ? (regime == 1 ? color.lime : color.red) : color.orange
trendCol  = regime == 1 ? color.lime : regime == -1 ? color.red : color.white

// ── Dashboard (chart TF only — Night 4 adds 1D+4H MTF rows) ─────────
// Mirror-format per SPEC §6: column ORDER matches paid tool (Time|Status|Trend).
// Position is configurable — validation needs both dashboards visible at once.
f_tfLabel(tf) =>
    switch tf
        "1"   => "1m"
        "3"   => "3m"
        "5"   => "5m"
        "15"  => "15m"
        "30"  => "30m"
        "60"  => "1H"
        "120" => "2H"
        "240" => "4H"
        "D"   => "D"
        "W"   => "W"
        "M"   => "M"
        => tf

dashLoc = dashPos == "Top Left" ? position.top_left : dashPos == "Top Right" ? position.top_right : dashPos == "Bottom Left" ? position.bottom_left : dashPos == "Middle Right" ? position.middle_right : position.bottom_right
var table dash = table.new(dashLoc, 3, 2, bgcolor=color.new(color.black, 15), border_width=1, border_color=color.new(color.gray, 70))
if barstate.islast and showDash
    table.cell(dash, 0, 0, "Time",   text_color=#f0c040, text_size=size.small)
    table.cell(dash, 1, 0, "Status", text_color=#f0c040, text_size=size.small)
    table.cell(dash, 2, 0, "Trend",  text_color=#f0c040, text_size=size.small)
    table.cell(dash, 0, 1, f_tfLabel(timeframe.period), text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 1, statusTxt, text_color=statusCol, text_size=size.small)
    table.cell(dash, 2, 1, trendTxt,  text_color=trendCol,  text_size=size.small)

// ── Developing (unconfirmed) leg — display only, feeds NOTHING ───────
var line devLine = na
if barstate.islast and showDev and array.size(zzPx) > 0 and not na(candPx)
    if na(devLine)
        devLine := line.new(na, na, na, na, style=line.style_dotted, color=devColor, width=lineW)
    lPx = array.get(zzPx, array.size(zzPx) - 1)
    lBx = array.get(zzBar, array.size(zzBar) - 1)
    line.set_xy1(devLine, lBx, lPx)
    line.set_xy2(devLine, candBar, candPx)
    line.set_color(devLine, devColor)

// ── Verification table (toggle in settings when needed) ─────────────
// rev D: created only when enabled — an empty table still claims its
// corner and covers whatever renders beneath it. Lives top_right so it
// can never collide with the dashboard even when both are on.
var table vt = showTbl ? table.new(position.top_right, 3, tblRows + 2, bgcolor=color.new(color.black, 20), border_width=1, border_color=color.new(color.gray, 70)) : na
if barstate.islast and showTbl
    n = array.size(zzPx)
    table.cell(vt, 0, 0, "Pivot",    text_color=#f0c040, text_size=size.small)
    table.cell(vt, 1, 0, "Price",    text_color=#f0c040, text_size=size.small)
    table.cell(vt, 2, 0, "Bars ago", text_color=#f0c040, text_size=size.small)
    rows = math.min(tblRows, n)
    if rows > 0
        for i = 0 to rows - 1
            idx = n - 1 - i
            d   = array.get(zzDir, idx)
            table.cell(vt, 0, i + 1, d == 1 ? "H" : "L", text_color=d == 1 ? color.red : color.lime, text_size=size.small)
            table.cell(vt, 1, i + 1, str.tostring(array.get(zzPx, idx), format.mintick), text_color=color.white, text_size=size.small)
            table.cell(vt, 2, i + 1, str.tostring(bar_index - array.get(zzBar, idx)), text_color=color.white, text_size=size.small)
    table.cell(vt, 0, rows + 1, "Total confirmed:", text_color=color.gray, text_size=size.small)
    table.cell(vt, 1, rows + 1, str.tostring(n), text_color=color.white, text_size=size.small)
